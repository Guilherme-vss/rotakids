# Copie este arquivo para .env e ajuste os valores.
# Com docker-compose, os valores abaixo já funcionam sem mudar nada.

PORT=3000

# Banco de dados PostgreSQL
DATABASE_URL=postgres://rotakids:rotakids@localhost:5432/rotakids

# Chave usada para assinar os tokens JWT — troque em produção!
JWT_SECRET=troque-esta-chave-em-producao
